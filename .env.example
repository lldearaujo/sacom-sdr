PORT=3000

# URL pública HTTPS do app (sem barra no final). Obrigatória para envio de mídia no WhatsApp (Z-API baixa /media/...).
# PUBLIC_BASE_URL=https://seu-dominio.com

# Tamanho máximo (bytes) ao baixar foto/vídeo/PDF/áudio recebidos pelo webhook (padrão ~15 MB).
# INBOUND_MEDIA_MAX_BYTES=15728640

# Debounce: aguarda silêncio após última mensagem antes de responder (agrupa várias bolhas do usuário).
# Use 0 para desativar o agrupamento (1 resposta por mensagem, mais rápido).
# WHATSAPP_DEBOUNCE_MS=2200
# WHATSAPP_DEBOUNCE_MAX_ITENS=15

# Resposta fracionada: tamanho máximo por bolha e pausa entre bolhas (ms).
# WHATSAPP_RESPOSTA_MAX_CHUNK=380
# WHATSAPP_RESPOSTA_DELAY_MIN_MS=550
# WHATSAPP_RESPOSTA_DELAY_MAX_MS=1300

# Objetivo comercial (linha "Objetivo:" do template padrão, quando BDR_SYSTEM_PROMPT estiver vazio)
# BDR_OBJETIVO_CONVERSA=Esclarecer dúvidas; sugerir call só se o lead pedir.

# Opcional: substitui o bloco de detecção de intenção (<intent>…</intent>). Vazio = padrão.
# BDR_INTENT_DETECCAO=## DETECÇÃO DE INTENÇÃO (OCULTA)\n...

# ── Economia de tokens (Gemini / RAG) ───────────────────────────────────────
# RAG_QUERY_MAX_CHARS=2000
# RAG_KNOWLEDGE_CHUNKS=2
# RAG_KNOWLEDGE_MAX_CHARS=520
# RAG_SIMILAR_LINE_MAX=120
# RAG_PERFIL_CAMPO_MAX=220
# RAG_HISTORICO_LIMITE=4
# RAG_HISTORICO_MSG_MAX_CHARS=900
# GEMINI_MAX_TOKENS=768
# GEMINI_PROSPECCAO_MAX_TOKENS=320
# GEMINI_INSIGHTS_MAX_TOKENS=560
# GEMINI_INSIGHTS_MAX_LEADS=22

ENRICHMENT_TTL_HOURS=168
MAX_ENRICHMENTS_PER_REQUEST=20
MAX_ENRICHMENT_CONCURRENCY=4
ENRICHMENT_DOMAIN_COOLDOWN_MS=600
ENRICHMENT_FETCH_TIMEOUT_MS=4000
ENRICHMENT_WARMUP_ENABLED=true
ENRICHMENT_WARMUP_HOUR=7
ENRICHMENT_WARMUP_MINUTE=0
ENRICHMENT_WARMUP_LIMIT=30
ENRICHMENT_WARMUP_SEGMENTS=Varejo,Saude,Automotivo,Educacao,Construcao e Imoveis
# ENRICHMENT_WARMUP_ON_START=false

# Z-API
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=

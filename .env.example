PORT=3000

# URL pública HTTPS do app (sem barra no final). Obrigatória para envio de mídia no WhatsApp (Z-API baixa /media/...).
# PUBLIC_BASE_URL=https://seu-dominio.com

# Tamanho máximo (bytes) ao baixar foto/vídeo/PDF/áudio recebidos pelo webhook (padrão ~15 MB).
# INBOUND_MEDIA_MAX_BYTES=15728640

# Objetivo comercial (linha "Objetivo:" do template padrão, quando BDR_SYSTEM_PROMPT estiver vazio)
# BDR_OBJETIVO_CONVERSA=Esclarecer dúvidas; sugerir call só se o lead pedir.

# Opcional: substitui o bloco de detecção de intenção (<intent>…</intent>). Vazio = padrão.
# BDR_INTENT_DETECCAO=## DETECÇÃO DE INTENÇÃO (OCULTA)\n...

ENRICHMENT_TTL_HOURS=168
MAX_ENRICHMENTS_PER_REQUEST=20
MAX_ENRICHMENT_CONCURRENCY=4
ENRICHMENT_DOMAIN_COOLDOWN_MS=600
ENRICHMENT_FETCH_TIMEOUT_MS=4000
